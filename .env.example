# ── Profit Matrix bot config ──────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# 1) Bot token from @BotFather (required)
BOT_TOKEN=123456:ABC-your-token-here

# 2) The link people tap to open your channel (required)
#    Public channel:  https://t.me/YourChannelUsername
#    Private channel: https://t.me/+InviteHashHere
CHANNEL_URL=https://t.me/ProfitMatrix

# 3) (Optional) channel @username — only needed if you want the bot to
#    VERIFY that a user actually joined. Public channels only.
CHANNEL_USERNAME=@ProfitMatrix

# 4) (Optional) turn membership verification on.
#    If true: bot must be an ADMIN of the channel and CHANNEL_USERNAME set.
#    If false: bot just shows a Join button (no verify step).
REQUIRE_JOIN=false

# 5) Brand name shown on buttons/messages
BRAND=Profit Matrix
